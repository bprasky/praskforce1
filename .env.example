# PraskForce1 — Environment Variables
# Copy to .env.local and fill in. .env.local is gitignored.

# ── Supabase (optional — engine falls back to JSON-in-response if missing) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Anthropic (Claude vision fallback for agent extraction) ──
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# ── Puppeteer (uses your installed Chrome via puppeteer-core) ──
# Windows default — adjust if Chrome is installed elsewhere
PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:   /usr/bin/google-chrome

# false = headed (visible browser window) — recommended for first-run debugging
# true  = headless
PUPPETEER_HEADLESS=false

# Slow each Puppeteer action by N ms so you can watch what's happening.
# Set to 0 once you trust it.
PUPPETEER_SLOWMO=50

# App runs in demo mode until Supabase keys are set
